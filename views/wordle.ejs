<!DOCTYPE html>
<html>

<head>

    <style>
        body{
            font-family: 'Segoe UI', Arial, sans-serif;
            background: linear-gradient(145deg, #f0f4ff, #e9eefa);
            margin:0;
            color:#333;
        }

        /* layout */
        .layout{
            display:flex;
            min-height:100vh;
        }

        /* боковое меню */
        .burger-btn {
            position: fixed;
            top: 25px;
            left: 25px;
            width: 50px;
            height: 50px;
            background: white;
            border-radius: 16px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 6px;
            cursor: pointer;
            z-index: 1001;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease;
            border: 1px solid rgba(99, 102, 241, 0.2);
        }

        .burger-btn:hover {
            transform: scale(1.02);
            box-shadow: 0 12px 24px rgba(79, 70, 229, 0.2);
        }

        .burger-btn span {
            display: block;
            width: 26px;
            height: 2.5px;
            background: #1e293b;
            border-radius: 4px;
            transition: 0.3s;
        }

        /* затемнение фона при открытом меню */
        .overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(3px);
            z-index: 1000;
            opacity: 0;
            visibility: hidden;
            transition: 0.3s;
        }

        .overlay.active {
            opacity: 1;
            visibility: visible;
        }

        /* боковое меню */
        .side-menu {
            position: fixed;
            top: 0;
            left: -320px;
            width: 300px;
            height: 100%;
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(20px);
            box-shadow: 4px 0 30px rgba(0, 0, 0, 0.1);
            z-index: 1002;
            transition: left 0.35s cubic-bezier(0.2, 0.9, 0.4, 1.1);
            padding: 1.8rem 0;
            display: flex;
            flex-direction: column;
            border-right: 1px solid rgba(99, 102, 241, 0.2);
        }

        .side-menu.open {
            left: 0;
        }

        .menu-header {
            padding: 0 1.5rem 1.2rem;
            border-bottom: 2px solid #e2e8f0;
            margin-bottom: 1rem;
        }

        .menu-header h3 {
            font-size: 1.4rem;
            background: linear-gradient(135deg, #4F46E5, #8B5CF6);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }

        .menu-items {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .menu-link {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 24px;
            text-decoration: none;
            color: #1e293b;
            font-weight: 500;
            transition: all 0.2s;
            border-left: 3px solid transparent;
        }

        .menu-link:hover {
            background: #f1f5f9;
            border-left-color: #4F46E5;
            padding-left: 28px;
        }

        .menu-link .menu-icon {
            font-size: 1.4rem;
            width: 28px;
            text-align: center;
        }

        .divider {
            height: 1px;
            background: #e2e8f0;
            margin: 12px 20px;
        }

        .menu-footer {
            padding-top: 1rem;
            border-top: 1px solid #e2e8f0;
            margin-top: auto;
        }

        /* основной контент */
        .main{
            flex:1;
            padding:30px;
            display:flex;
            flex-direction:column;
            align-items:center;
            gap:20px;
        }

        /* карточка */
        .container-game{
            background:white;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
            padding:30px;
            border-radius:20px;
            width:100%;
            max-width:600px;
            text-align:center;
        }

        /* select блок */
        .selectLevel{
            background:white;
            box-shadow: 0 6px 15px rgba(0,0,0,0.1);
            padding:20px;
            border-radius:20px;
            width:100%;
            max-width:400px;

            display:flex;
            flex-direction:column;
            gap:10px;

            transition:0.3s;
        }

        /* 🔥 авто-увеличение при фокусе */
        .selectLevel:focus-within{
            transform: scale(1.05);
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }

        /* input */
        input{
            width:80%;
            padding:12px;
            border-radius:12px;
            border:1px solid #ddd;
        }

        /* select */
        select{
            width:100%;
            padding:10px;
            border-radius:12px;
        }

        /* кнопки */
        button{
            padding:12px;
            border:none;
            border-radius:12px;
            background:#4facfe;
            color:white;
            font-weight:bold;
            cursor:pointer;
            transition:0.2s;
            margin-top: 15px;
        }

        button:hover{
            transform:scale(1.005);
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            background: #5aaffa;
        }

        /* XP */
        .xp{
            background:white;
            padding:12px 20px;
            border-radius:12px;
            display:flex;
            gap:20px;
        }

        /* 📱 адаптив */
        @media (max-width: 768px){
            .layout{
                flex-direction:column;
            }

            .sidebar{
                width:100%;
                flex-direction:row;
                overflow-x:auto;
            }

            .main{
                padding:15px;
            }
        }
    </style>
</head>

<body>

<div class="layout">

    <div class="burger-btn" id="burgerBtn">
        <span></span>
        <span></span>
        <span></span>
    </div>

    <!-- Затемнение -->
    <div class="overlay" id="overlay"></div>

    <!-- Боковое меню навигации -->
    <nav class="side-menu" id="sideMenu">
        <div class="menu-header">
            <h3>📚 English Trainer</h3>
        </div>
        <div class="menu-items">
            <a href="/" class="menu-link" id="navHome">
                <span class="menu-icon">🏠</span>
                <span>Главная</span>
            </a>
            <div class="divider"></div>
            <a href="#" class="menu-link" id="navAuth">
                <span class="menu-icon">🔐</span>
                <span>Регистрация / Вход</span>
            </a>
            <div class="divider"></div>
            <a href="#" class="menu-link" id="navGames">
                <span class="menu-icon">🎮</span>
                <span>Игры</span>
            </a>
            <a href="/reader" class="menu-link" id="navReading">
                <span class="menu-icon">📖</span>
                <span>Чтение книг</span>
            </a>
            <div class="divider"></div>
            <a href="#" class="menu-link" id="navAbout">
                <span class="menu-icon">ℹ️</span>
                <span>О нас</span>
            </a>
            <a href="#" class="menu-link" id="navCourses">
                <span class="menu-icon">🎓</span>
                <span>Купить курсы</span>
            </a>
        </div>
        <div class="menu-footer">
            <div class="menu-link" style="opacity:0.7;">
                <span class="menu-icon">⚡</span>
                <span>v2.0 — Учись играя</span>
            </div>
        </div>
    </nav>


    <!-- основной контент -->
    <div class="main">

        <h1>Translate the word</h1>

        <div class="container-game">
            <p>Translate this English word into Russian:</p>

            <h2><%= word %></h2>

            <input id="guess" placeholder="Введите перевод на русском">
            <button onclick="check()">Проверить</button>

            <p id="result"></p>
            <p id="hint"></p>
        </div>

        <div class="selectLevel">
            <select id="levelSelect">
                <option value="A">A1-A2</option>
                <option value="B">B1-B2</option>
                <option value="C">C1-C2</option>
            </select>
            <button onclick="changeLevel()">Выбрать уровень</button>
        </div>

        <div class="xp">
            XP: <span id="xp">0</span>
            Level: <span id="level">1</span>
        </div>

    </div>

</div>

    <script>
        function changeLevel() {
            const level = document.getElementById("levelSelect").value;
            window.location.href = "/wordle?level=" + level;
        }
        const translation = "<%= translation %>".toLowerCase();
        const translation2 = "<%= translation2 %>".toLowerCase();
        let attempts = 3;

        function check() {
            const input = document.getElementById("guess");
            const result = document.getElementById("result");
            const hint = document.getElementById("hint");
            const g = input.value.trim().toLowerCase();

            if (!g) {
                result.innerText = "Введите перевод";
                return;
            }

            if (g === translation || g === translation2) {
                result.innerText = "Отлично! +" + 20 + " XP";
                addXP(20);
                input.disabled = true;

                // Через секунду загружаем новое слово
                setTimeout(() => {
                    const level = new URLSearchParams(window.location.search).get("level") || "A";
                    window.location.href = "/wordle?level=" + level;
                }, 1000);
                return;
            }

            attempts--;
            if (attempts <= 0) {
                result.innerText = "Попытки закончились. Правильный перевод: " + translation;
                input.disabled = true;

                // Показываем правильный ответ и сразу новое слово
                setTimeout(() => {
                    const level = new URLSearchParams(window.location.search).get("level") || "A";
                    window.location.href = "/wordle?level=" + level;
                }, 1000);
                return;
            }

            result.innerText = "Неправильно. Осталось попыток: " + attempts;
            hint.innerText = "Подсказка: перевод начинается с \"" + translation[0] + "\"";
        }
        // ========== БУРГЕР МЕНЮ (навигация) ==========
        const burger = document.getElementById('burgerBtn');
        const sideMenu = document.getElementById('sideMenu');
        const overlay = document.getElementById('overlay');

        function closeMenu() {
            sideMenu.classList.remove('open');
            overlay.classList.remove('active');
        }

        function openMenu() {
            sideMenu.classList.add('open');
            overlay.classList.add('active');
        }

        burger.addEventListener('click', (e) => {
            e.stopPropagation();
            if (sideMenu.classList.contains('open')) closeMenu();
            else openMenu();
        });

        overlay.addEventListener('click', closeMenu);

        // пункты меню (заглушки для демонстрации навигации, дизайн не требует функционала, но я добавлю алерты, чтобы показать работу)
        const navAuth = document.getElementById('navAuth');
        const navGames = document.getElementById('navGames');
        const navReading = document.getElementById('navReading');
        const navAbout = document.getElementById('navAbout');
        const navCourses = document.getElementById('navCourses');

        if(navAuth) navAuth.addEventListener('click', (e) => { e.preventDefault(); closeMenu(); alert('🔐 Форма регистрации и входа — здесь будет удобная авторизация.'); });
        if(navGames) navGames.addEventListener('click', (e) => { e.preventDefault(); closeMenu(); document.querySelector('.games-grid').scrollIntoView({behavior: 'smooth', block: 'start'}); });
        if(navReading) navReading.addEventListener('click', (e) => { e.preventDefault(); closeMenu(); document.querySelector('.reading-section').scrollIntoView({behavior: 'smooth', block: 'start'}); });
        if(navAbout) navAbout.addEventListener('click', (e) => { e.preventDefault(); closeMenu(); alert('ℹ️ English Trainer — интерактивная платформа для изучения английского через игры и чтение. Создано для эффективного обучения.'); });
        if(navCourses) navCourses.addEventListener('click', (e) => { e.preventDefault(); closeMenu(); alert('🎓 Расширенные курсы: индивидуальный план, уроки с носителем, доступ к библиотеке. Скоро запуск!'); });

    </script>

    <script src="/xp.js"></script>
</body>

</html>