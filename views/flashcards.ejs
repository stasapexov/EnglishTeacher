<!DOCTYPE html>
<html>

<head>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <h1>Flashcards</h1>

    <div class="card">
        <div class="card-inner">
            <div class="card-front">
                <%= word %>
            </div>
            <div class="card-back">
                Click to learn this word
            </div>
        </div>
    </div>

    <br>
    <a href="/flashcards">Next</a>

    <div class="xp">
        XP: <span id="xp">0</span>
        Level: <span id="level">1</span>
    </div>

    <script src="/xp.js"></script>
</body>

</html>