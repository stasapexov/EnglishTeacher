<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Домашнее задание</title>
    <style>
        body{
            font-family: 'Segoe UI', Arial, sans-serif;
            background: linear-gradient(145deg, #f0f4ff, #e9eefa);
            margin:0;
            color:#333;
        }

        .layout{
            display:flex;
            min-height:100vh;
        }

        .burger-btn {
            position: fixed;
            top: 25px;
            left: 25px;
            width: 50px;
            height: 50px;
            background: white;
            border-radius: 16px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 6px;
            cursor: pointer;
            z-index: 1001;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease;
            border: 1px solid rgba(99, 102, 241, 0.2);
        }

        .burger-btn:hover {
            transform: scale(1.02);
            box-shadow: 0 12px 24px rgba(79, 70, 229, 0.2);
        }

        .burger-btn span {
            display: block;
            width: 26px;
            height: 2.5px;
            background: #1e293b;
            border-radius: 4px;
            transition: 0.3s;
        }

        .overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(3px);
            z-index: 1000;
            opacity: 0;
            visibility: hidden;
            transition: 0.3s;
        }

        .overlay.active {
            opacity: 1;
            visibility: visible;
        }

        .side-menu {
            position: fixed;
            top: 0;
            left: -320px;
            width: 300px;
            height: 100%;
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(20px);
            box-shadow: 4px 0 30px rgba(0, 0, 0, 0.1);
            z-index: 1002;
            transition: left 0.35s cubic-bezier(0.2, 0.9, 0.4, 1.1);
            padding: 1.8rem 0;
            display: flex;
            flex-direction: column;
            border-right: 1px solid rgba(99, 102, 241, 0.2);
        }

        .side-menu.open {
            left: 0;
        }

        .menu-header {
            padding: 0 1.5rem 1.2rem;
            border-bottom: 2px solid #e2e8f0;
            margin-bottom: 1rem;
        }

        .menu-header h3 {
            font-size: 1.4rem;
            background: linear-gradient(135deg, #4F46E5, #8B5CF6);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }

        .menu-items {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .menu-link {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 24px;
            text-decoration: none;
            color: #1e293b;
            font-weight: 500;
            transition: all 0.2s;
            border-left: 3px solid transparent;
        }

        .menu-link:hover {
            background: #f1f5f9;
            border-left-color: #4F46E5;
            padding-left: 28px;
        }

        .menu-link .menu-icon {
            font-size: 1.4rem;
            width: 28px;
            text-align: center;
        }

        .divider {
            height: 1px;
            background: #e2e8f0;
            margin: 12px 20px;
        }

        .menu-footer {
            padding-top: 1rem;
            border-top: 1px solid #e2e8f0;
            margin-top: auto;
        }

        .main{
            flex:1;
            padding:30px;
            display:flex;
            flex-direction:column;
            align-items:center;
            gap:20px;
        }

        .container-game{
            background:white;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
            padding:30px;
            border-radius:20px;
            width:100%;
            max-width:700px;
            text-align:center;
        }

        .selectLevel{
            background:white;
            box-shadow: 0 6px 15px rgba(0,0,0,0.1);
            padding:20px;
            border-radius:20px;
            width:100%;
            max-width:430px;
            display:flex;
            flex-direction:column;
            gap:10px;
            transition:0.3s;
        }

        .selectLevel:focus-within{
            transform: scale(1.05);
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }

        select, .option-input{
            width:100%;
            padding:11px;
            border-radius:12px;
            border:1px solid #ddd;
            font-size: 1rem;
        }

        button{
            padding:12px;
            border:none;
            border-radius:12px;
            background:#4facfe;
            color:white;
            font-weight:bold;
            cursor:pointer;
            transition:0.2s;
            margin-top: 10px;
        }

        button:hover{
            transform:scale(1.005);
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            background: #5aaffa;
        }

        .question{
            text-align:left;
            padding:14px;
            border:1px solid #e5e7eb;
            border-radius:14px;
            margin-bottom:12px;
            background:#f8fbff;
        }

        .question h3{
            margin: 0 0 10px;
            font-size: 1rem;
            color: #1e293b;
        }

        .option{
            display:block;
            margin: 8px 0;
        }

        .option input{
            margin-right:8px;
        }

        .hidden{
            display:none;
        }

        .grade-box{
            margin-top: 16px;
            padding: 14px;
            border-radius: 12px;
            background: #eef6ff;
            border: 1px solid #bfdbfe;
            font-size: 1.1rem;
            font-weight: 600;
        }

        .xp{
            background:white;
            padding:12px 20px;
            border-radius:12px;
            display:flex;
            gap:20px;
        }
    </style>
</head>

<body>
<div class="layout">

    <div class="burger-btn" id="burgerBtn">
        <span></span>
        <span></span>
        <span></span>
    </div>

    <div class="overlay" id="overlay"></div>

    <nav class="side-menu" id="sideMenu">
        <div class="menu-header">
            <h3>📚 English Trainer</h3>
        </div>
        <div class="menu-items">
            <a href="/" class="menu-link"><span class="menu-icon">🏠</span><span>Главная</span></a>
            <div class="divider"></div>
            <a href="#" class="menu-link"><span class="menu-icon">🔐</span><span>Регистрация / Вход</span></a>
            <div class="divider"></div>
            <a href="#" class="menu-link"><span class="menu-icon">🎮</span><span>Игры</span></a>
            <a href="/reader" class="menu-link"><span class="menu-icon">📖</span><span>Чтение книг</span></a>
            <div class="divider"></div>
            <a href="#" class="menu-link"><span class="menu-icon">ℹ️</span><span>О нас</span></a>
            <a href="#" class="menu-link"><span class="menu-icon">🎓</span><span>Купить курсы</span></a>
        </div>
        <div class="menu-footer">
            <div class="menu-link" style="opacity:0.7;"><span class="menu-icon">⚡</span><span>v2.0 — Учись играя</span></div>
        </div>
    </nav>

    <div class="main">
        <h1>Домашнее задание</h1>

        <div class="selectLevel">
            <select id="levelSelect">
                <option value="6">6 Класс</option>
                <option value="7">7 Класс</option>
                <option value="8">8 Класс</option>
                <option value="9">9 Класс</option>
            </select>
            <button onclick="changeLevel()">Выбрать свой класс</button>
        </div>

        <div class="container-game hidden" id="homeworkBlock">
            <p id="classTitle"></p>
            <div id="questionsContainer"></div>
            <button onclick="checkHomework()">Проверить ответы</button>
            <div id="gradeResult" class="grade-box hidden"></div>
        </div>

        <div class="xp">
            XP: <span id="xp">0</span>
            Level: <span id="level">1</span>
        </div>
    </div>

</div>

<script>
    const homeworkByClass = {
        6: [
            { q: "Выбери правильный перевод слова 'school'", options: ["школа", "шар", "сахар"], correct: 0 },
            { q: "Какой артикль нужен: ___ apple", options: ["a", "an", "the"], correct: 1 },
            { q: "Выбери форму глагола: I ___ a book every day.", options: ["read", "reads", "reading"], correct: 0 },
            { q: "Перевод слова 'cat'", options: ["кот", "кит", "код"], correct: 0 },
            { q: "Как правильно: He ___ my friend.", options: ["am", "is", "are"], correct: 1 }
        ],
        7: [
            { q: "Выбери Past Simple: go", options: ["goed", "went", "gone"], correct: 1 },
            { q: "Найди правильный перевод: beautiful", options: ["быстрый", "красивый", "маленький"], correct: 1 },
            { q: "We ___ football yesterday.", options: ["played", "play", "plays"], correct: 0 },
            { q: "Выбери верное местоимение: This is ___ bag.", options: ["I", "me", "my"], correct: 2 },
            { q: "She ___ to music now.", options: ["listening", "is listening", "listen"], correct: 1 }
        ],
        8: [
            { q: "If I ___ time, I will help you.", options: ["have", "had", "will have"], correct: 0 },
            { q: "Выбери синоним к 'smart'", options: ["clever", "slow", "weak"], correct: 0 },
            { q: "Passive Voice: The book ___ by Tom.", options: ["writes", "is written", "wrote"], correct: 1 },
            { q: "Перевод 'environment'", options: ["окружение", "эксперимент", "энергия"], correct: 0 },
            { q: "I have lived here ___ 2020.", options: ["for", "since", "at"], correct: 1 }
        ],
        9: [
            { q: "Reported speech: He said that he ___ tired.", options: ["is", "was", "were"], correct: 1 },
            { q: "Choose the correct word: This task is very ___.", options: ["challenge", "challenging", "challenged"], correct: 1 },
            { q: "Conditionals: If I had known, I ___ come.", options: ["would", "would have", "will"], correct: 1 },
            { q: "Выбери правильный перевод 'achievement'", options: ["достижение", "поражение", "решение"], correct: 0 },
            { q: "Neither Tom nor his friends ___ at home.", options: ["is", "are", "be"], correct: 1 }
        ]
    };

    let currentClass = null;

    function changeLevel() {
        currentClass = document.getElementById("levelSelect").value;
        const questions = homeworkByClass[currentClass];
        const block = document.getElementById("homeworkBlock");
        const classTitle = document.getElementById("classTitle");
        const container = document.getElementById("questionsContainer");
        const gradeResult = document.getElementById("gradeResult");

        classTitle.innerHTML = `<strong>Домашняя работа для ${currentClass} класса</strong> (5 вопросов)`;
        container.innerHTML = "";
        gradeResult.classList.add("hidden");
        gradeResult.innerText = "";

        questions.forEach((question, qIndex) => {
            const questionDiv = document.createElement("div");
            questionDiv.className = "question";

            let optionsHtml = "";
            question.options.forEach((option, oIndex) => {
                optionsHtml += `
                    <label class="option">
                        <input class="option-input" type="radio" name="q${qIndex}" value="${oIndex}">
                        ${option}
                    </label>
                `;
            });

            questionDiv.innerHTML = `<h3>${qIndex + 1}. ${question.q}</h3>${optionsHtml}`;
            container.appendChild(questionDiv);
        });

        block.classList.remove("hidden");
    }

    function checkHomework() {
        if (!currentClass) return;

        const questions = homeworkByClass[currentClass];
        let score = 0;

        questions.forEach((question, qIndex) => {
            const selected = document.querySelector(`input[name="q${qIndex}"]:checked`);
            if (selected && Number(selected.value) === question.correct) {
                score++;
            }
        });

        const grade = getGrade(score);
        const result = document.getElementById("gradeResult");
        result.innerText = `Результат: ${score}/5. Твоя оценка: ${grade}`;
        result.classList.remove("hidden");

        if (typeof addXP === "function") {
            addXP(score * 5);
        }
    }

    function getGrade(score) {
        if (score === 5) return "5 (Отлично)";
        if (score === 4) return "4 (Хорошо)";
        if (score === 3) return "3 (Удовлетворительно)";
        return "2 (Нужно повторить тему)";
    }

    const burger = document.getElementById('burgerBtn');
    const sideMenu = document.getElementById('sideMenu');
    const overlay = document.getElementById('overlay');

    function closeMenu() {
        sideMenu.classList.remove('open');
        overlay.classList.remove('active');
    }

    function openMenu() {
        sideMenu.classList.add('open');
        overlay.classList.add('active');
    }

    burger.addEventListener('click', (e) => {
        e.stopPropagation();
        if (sideMenu.classList.contains('open')) closeMenu();
        else openMenu();
    });

    overlay.addEventListener('click', closeMenu);
</script>

<script src="/xp.js"></script>
</body>

</html>
