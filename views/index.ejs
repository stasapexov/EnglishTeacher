<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>English Trainer | Изучай английский с удовольствием</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(145deg, #f0f4ff 0%, #e9eefa 100%);
            font-family: 'Segoe UI', 'Poppins', 'Inter', system-ui, -apple-system, 'Roboto', sans-serif;
            min-height: 100vh;
            padding: 2rem 1.5rem;
            position: relative;
        }

        /* декоративные фоновые элементы */
        body::before {
            content: "";
            position: absolute;
            top: -20%;
            left: -10%;
            width: 280px;
            height: 280px;
            background: radial-gradient(circle, rgba(99, 102, 241, 0.08) 0%, rgba(99, 102, 241, 0) 70%);
            border-radius: 50%;
            z-index: 0;
        }

        body::after {
            content: "";
            position: absolute;
            bottom: -15%;
            right: -5%;
            width: 340px;
            height: 340px;
            background: radial-gradient(circle, rgba(245, 158, 11, 0.08) 0%, rgba(245, 158, 11, 0) 70%);
            border-radius: 50%;
            z-index: 0;
        }

        /* ========== БУРГЕР МЕНЮ ========== */
        .burger-btn {
            position: fixed;
            top: 25px;
            left: 25px;
            width: 50px;
            height: 50px;
            background: white;
            border-radius: 16px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 6px;
            cursor: pointer;
            z-index: 1001;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease;
            border: 1px solid rgba(99, 102, 241, 0.2);
        }

        .burger-btn:hover {
            transform: scale(1.02);
            box-shadow: 0 12px 24px rgba(79, 70, 229, 0.2);
        }

        .burger-btn span {
            display: block;
            width: 26px;
            height: 2.5px;
            background: #1e293b;
            border-radius: 4px;
            transition: 0.3s;
        }

        /* затемнение фона при открытом меню */
        .overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(3px);
            z-index: 1000;
            opacity: 0;
            visibility: hidden;
            transition: 0.3s;
        }

        .overlay.active {
            opacity: 1;
            visibility: visible;
        }

        /* боковое меню */
        .side-menu {
            position: fixed;
            top: 0;
            left: -320px;
            width: 300px;
            height: 100%;
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(20px);
            box-shadow: 4px 0 30px rgba(0, 0, 0, 0.1);
            z-index: 1002;
            transition: left 0.35s cubic-bezier(0.2, 0.9, 0.4, 1.1);
            padding: 1.8rem 0;
            display: flex;
            flex-direction: column;
            border-right: 1px solid rgba(99, 102, 241, 0.2);
        }

        .side-menu.open {
            left: 0;
        }

        .menu-header {
            padding: 0 1.5rem 1.2rem;
            border-bottom: 2px solid #e2e8f0;
            margin-bottom: 1rem;
        }

        .menu-header h3 {
            font-size: 1.4rem;
            background: linear-gradient(135deg, #4F46E5, #8B5CF6);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }

        .menu-items {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .menu-link {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 24px;
            text-decoration: none;
            color: #1e293b;
            font-weight: 500;
            transition: all 0.2s;
            border-left: 3px solid transparent;
        }

        .menu-link:hover {
            background: #f1f5f9;
            border-left-color: #4F46E5;
            padding-left: 28px;
        }

        .menu-link .menu-icon {
            font-size: 1.4rem;
            width: 28px;
            text-align: center;
        }

        .divider {
            height: 1px;
            background: #e2e8f0;
            margin: 12px 20px;
        }

        .menu-footer {
            padding-top: 1rem;
            border-top: 1px solid #e2e8f0;
            margin-top: auto;
        }

        /* главная карточка */
        .glass-card {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            border-radius: 3.5rem;
            box-shadow: 0 25px 45px -12px rgba(0, 0, 0, 0.25);
            padding: 2rem 2rem 2.5rem;
            width: 100%;
            max-width: 1300px;
            margin: 0 auto;
            border: 1px solid rgba(255, 255, 255, 0.6);
            z-index: 2;
            position: relative;
        }

        /* шапка */
        .hero {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: baseline;
            margin-bottom: 2.5rem;
            border-bottom: 2px solid rgba(99, 102, 241, 0.2);
            padding-bottom: 1rem;
        }

        h1 {
            font-size: 2.5rem;
            font-weight: 800;
            background: linear-gradient(135deg, #1E2A5E, #4F46E5);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }

        .xp-panel {
            background: #1e293b;
            padding: 0.6rem 1.4rem;
            border-radius: 60px;
            display: flex;
            gap: 1.5rem;
            font-weight: 600;
        }

        .xp-panel span:first-child, .xp-panel span:last-child {
            color: #cbd5e1;
            font-size: 0.9rem;
        }

        .xp-panel span:nth-child(2), .xp-panel span:nth-child(4) {
            color: #facc15;
            font-size: 1.2rem;
            font-weight: 800;
            background: #0f172a;
            padding: 0 0.4rem;
            border-radius: 28px;
            min-width: 48px;
            display: inline-block;
            text-align: center;
        }

        /* секция игр */
        .section-title {
            font-size: 1.8rem;
            font-weight: 700;
            margin: 1.8rem 0 1.2rem;
            display: flex;
            align-items: center;
            gap: 12px;
            color: #1e293b;
        }

        .section-title span {
            background: #4F46E5;
            width: 40px;
            height: 4px;
            border-radius: 4px;
        }

        .games-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
            gap: 1.8rem;
            margin-bottom: 1rem;
        }

        /* карточки игр и чтения */
        .menu-item {
            background: white;
            border-radius: 2rem;
            padding: 1.6rem 0.8rem 1.3rem;
            text-align: center;
            text-decoration: none;
            transition: all 0.3s cubic-bezier(0.2, 0.9, 0.4, 1.1);
            box-shadow: 0 12px 22px -10px rgba(0, 0, 0, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.7);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.6rem;
        }

        .menu-item:hover {
            transform: translateY(-6px);
            box-shadow: 0 28px 34px -16px rgba(79, 70, 229, 0.25);
            border-color: rgba(99, 102, 241, 0.4);
        }

        .menu-icon {
            font-size: 3rem;
            filter: drop-shadow(0 4px 6px rgba(0, 0, 0, 0.1));
        }

        .menu-title {
            font-size: 1.5rem;
            font-weight: 700;
            background: linear-gradient(145deg, #1f2937, #4b5563);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }

        .menu-desc {
            font-size: 0.8rem;
            color: #6c757d;
        }

        /* Секция Reading Room (отдельное пространство) */
        .reading-section {
            margin-top: 3rem;
            background: linear-gradient(135deg, rgba(139, 92, 246, 0.08), rgba(99, 102, 241, 0.05));
            border-radius: 2rem;
            padding: 1.5rem 1.8rem;
            border: 1px solid rgba(139, 92, 246, 0.3);
            transition: all 0.3s;
        }

        .reading-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 1.2rem;
        }

        .reading-header h2 {
            font-size: 1.7rem;
            font-weight: 700;
            background: linear-gradient(135deg, #8B5CF6, #6D28D9);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }

        .feature-badge {
            background: #8B5CF6;
            color: white;
            font-size: 0.7rem;
            padding: 4px 12px;
            border-radius: 30px;
            font-weight: 500;
        }

        .reading-card {
            display: flex;
            flex-wrap: wrap;
            gap: 1.8rem;
            align-items: stretch;
        }

        .reading-info {
            flex: 2;
            min-width: 200px;
            background: white;
            border-radius: 1.5rem;
            padding: 1.5rem;
            box-shadow: 0 8px 18px rgba(0,0,0,0.05);
        }

        .reading-info p {
            margin: 1rem 0;
            line-height: 1.5;
            color: #334155;
        }

        .feature-list {
            list-style: none;
            margin: 1rem 0;
        }

        .feature-list li {
            margin: 12px 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .feature-list li::before {
            content: "✨";
        }

        .cta-button {
            display: inline-block;
            background: linear-gradient(135deg, #8B5CF6, #6D28D9);
            color: white;
            padding: 12px 28px;
            border-radius: 40px;
            text-decoration: none;
            font-weight: 600;
            margin-top: 12px;
            transition: 0.2s;
            box-shadow: 0 4px 10px rgba(139, 92, 246, 0.3);
        }

        .cta-button:hover {
            transform: scale(1.02);
            box-shadow: 0 8px 20px rgba(139, 92, 246, 0.4);
        }

        .book-preview {
            flex: 1.2;
            background: linear-gradient(145deg, #f8fafc, #ffffff);
            border-radius: 1.5rem;
            padding: 1.2rem;
            text-align: center;
            border: 1px solid #e2e8f0;
        }

        .book-cover {
            font-size: 3.5rem;
            margin-bottom: 8px;
        }

        .book-title {
            font-weight: 700;
            margin: 8px 0;
        }

        .demo-translate {
            background: #f1f5f9;
            padding: 8px 12px;
            border-radius: 40px;
            font-size: 0.8rem;
            display: inline-block;
            margin-top: 12px;
        }

        /* вдохновляющее сообщение */
        .inspire-message {
            margin-top: 2.5rem;
            text-align: center;
            font-size: 0.85rem;
            background: rgba(255,255,240,0.7);
            padding: 0.6rem 1rem;
            border-radius: 60px;
            width: fit-content;
            margin-left: auto;
            margin-right: auto;
            color: #334155;
        }

        @media (max-width: 680px) {
            body { padding: 1rem; }
            .glass-card { padding: 1.2rem; }
            h1 { font-size: 1.8rem; }
            .hero { flex-direction: column; gap: 1rem; }
            .section-title { font-size: 1.5rem; }
            .reading-section { padding: 1rem; }
        }
    </style>
</head>
<body>

<!-- Бургер кнопка -->
<div class="burger-btn" id="burgerBtn">
    <span></span>
    <span></span>
    <span></span>
</div>

<!-- Затемнение -->
<div class="overlay" id="overlay"></div>

<!-- Боковое меню навигации -->
<nav class="side-menu" id="sideMenu">
    <div class="menu-header">
        <h3>📚 English Trainer</h3>
    </div>
    <div class="menu-items">
        <a href="#" class="menu-link" id="navHome">
            <span class="menu-icon">🏠</span>
            <span>Главная</span>
        </a>
        <div class="divider"></div>
        <a href="#" class="menu-link" id="navAuth">
            <span class="menu-icon">🔐</span>
            <span>Регистрация / Вход</span>
        </a>
        <div class="divider"></div>
        <a href="#" class="menu-link" id="navGames">
            <span class="menu-icon">🎮</span>
            <span>Игры</span>
        </a>
        <a href="/reader" class="menu-link" id="navReading">
            <span class="menu-icon">📖</span>
            <span>Чтение книг</span>
        </a>
        <div class="divider"></div>
        <a href="#" class="menu-link" id="navAbout">
            <span class="menu-icon">ℹ️</span>
            <span>О нас</span>
        </a>
        <a href="#" class="menu-link" id="navCourses">
            <span class="menu-icon">🎓</span>
            <span>Купить курсы</span>
        </a>
    </div>
    <div class="menu-footer">
        <div class="menu-link" style="opacity:0.7;">
            <span class="menu-icon">⚡</span>
            <span>v2.0 — Учись играя</span>
        </div>
    </div>
</nav>

<div class="glass-card">
    <div class="hero">
        <h1>English Trainer</h1>
        <div class="xp-panel">
            <span>🏆 XP</span>
            <span id="xp">0</span>
            <span>📈 Уровень</span>
            <span id="level">1</span>
        </div>
    </div>

    <!-- СЕКЦИЯ ИГР -->
    <div class="section-title">
        <span></span> 🎲 Игровой центр
    </div>
    <div class="games-grid">
        <a href="/learn" class="menu-item" data-color="learn">
            <div class="menu-icon">📘</div>
            <div class="menu-title">Изучать</div>
            <div class="menu-desc">Слова и грамматика · Интерактив</div>
        </a>
        <a href="/guess" class="menu-item" data-color="guess">
            <div class="menu-icon">🔍</div>
            <div class="menu-title">Новое слово</div>
            <div class="menu-desc">Изучай и запоминай новые для себя слова</div>
        </a>
        <a href="/builder" class="menu-item" data-color="builder">
            <div class="menu-icon">🏗️</div>
            <div class="menu-title">Конструктор</div>
            <div class="menu-desc">Строй сломанные слова</div>
        </a>
        <a href="/wordle" class="menu-item" data-color="wordle">
            <div class="menu-icon">🎯</div>
            <div class="menu-title">Wordle</div>
            <div class="menu-desc">Ежедневный вызов</div>
        </a>
    </div>

    <!-- ОТДЕЛЬНОЕ ПРОСТРАНСТВО: READING ROOM (ЧТЕНИЕ КНИГ) -->
    <div class="reading-section">
        <div class="reading-header">
            <p>📖</p>
            <h2>Reading Room</h2>
            <div class="feature-badge">Новый формат</div>
        </div>
        <div class="reading-card">
            <div class="reading-info">
                <p><strong>✨ Погружение в мир английской литературы</strong> — учи язык через увлекательное чтение.</p>
                <ul class="feature-list">
                    <li><strong>Выбор книг</strong> — от классики до современных бестселлеров, адаптированные под ваш уровень.</li>
                    <li><strong>Интерактивный перевод</strong> — нажми на любое незнакомое слово, и мгновенно появится перевод, транскрипция и пример использования.</li>
                    <li><strong>Словарь на лету</strong> — сохраняй слова в личный набор для повторения.</li>
                    <li><strong>Аудиосопровождение</strong> — слушай профессиональное озвучивание отрывков (опционально).</li>
                </ul>
                <a href="/reader" class="cta-button">📚 Перейти в библиотеку →</a>
            </div>
            <div class="book-preview">
                <div class="book-cover">📘✨</div>
                <div class="book-title"><strong>Robinson Crusoe</strong></div>
                <div class="demo-translate">💡 Нажми на слово <span style="background:#e2e8f0; padding:2px 6px; border-radius:12px;">Sea</span> → перевод: <strong>(Море)</strong></div>
                <div style="margin-top: 10px; font-size: 0.7rem; color:#64748b;">* Функция перевода по клику доступна в читалке</div>
            </div>
        </div>
        <div style="margin-top: 1rem; font-size: 0.8rem; color:#475569; background: rgba(255,255,240,0.6); border-radius: 40px; padding: 8px 14px; text-align: center;">
            🧠 Книги с умным переводчиком — учись, читая с удовольствием!
        </div>
    </div>

    <div class="inspire-message">
        💡 <span>Тренируйся каждый день</span> — выполняй задания, получай опыт и повышай уровень!
    </div>
</div>

<script>
    (function() {
        // ========== XP И УРОВНИ (чистый дизайн, но я оставлю минимальную работу XP, чтобы панель была живой) ==========
        const xpSpan = document.getElementById('xp');
        const levelSpan = document.getElementById('level');
        const getXpNeeded = (lvl) => 80 + (lvl - 1) * 55;
        let currentXP = 0, currentLevel = 1;

        function loadProgress() {
            try {
                const savedXP = localStorage.getItem('englishTrainer_xp');
                const savedLevel = localStorage.getItem('englishTrainer_level');
                if (savedXP !== null && !isNaN(parseInt(savedXP))) currentXP = parseInt(savedXP);
                if (savedLevel !== null && !isNaN(parseInt(savedLevel))) currentLevel = parseInt(savedLevel);
                recalc();
            } catch(e) {}
            updateUI();
        }

        function recalc() {
            while (currentLevel < 100 && currentXP >= getXpNeeded(currentLevel)) {
                currentXP -= getXpNeeded(currentLevel);
                currentLevel++;
            }
            if (typeof localStorage !== 'undefined') {
                localStorage.setItem('englishTrainer_xp', currentXP);
                localStorage.setItem('englishTrainer_level', currentLevel);
            }
        }

        function updateUI() {
            if (xpSpan) xpSpan.innerText = currentXP;
            if (levelSpan) levelSpan.innerText = currentLevel;
        }

        window.addXP = function(amount) {
            if (!amount) return;
            currentXP += amount;
            recalc();
            updateUI();
        };

        loadProgress();

        // маленькая анимация для XP панели (декоративная)
        const panel = document.querySelector('.xp-panel');
        if(panel) {
            panel.addEventListener('dblclick', () => {
                window.addXP(5);
                showFloatingMsg('🎁 +5 XP (пасхалка)', panel);
            });
        }

        function showFloatingMsg(text, target) {
            let div = document.createElement('div');
            div.innerText = text;
            div.style.position = 'fixed';
            div.style.background = '#4F46E5';
            div.style.color = 'white';
            div.style.padding = '6px 14px';
            div.style.borderRadius = '30px';
            div.style.fontSize = '0.8rem';
            div.style.zIndex = '999';
            div.style.pointerEvents = 'none';
            let rect = target.getBoundingClientRect();
            div.style.left = rect.left + 'px';
            div.style.top = (rect.top - 30) + 'px';
            document.body.appendChild(div);
            setTimeout(() => div.remove(), 1000);
        }

        // ========== БУРГЕР МЕНЮ (навигация) ==========
        const burger = document.getElementById('burgerBtn');
        const sideMenu = document.getElementById('sideMenu');
        const overlay = document.getElementById('overlay');

        function closeMenu() {
            sideMenu.classList.remove('open');
            overlay.classList.remove('active');
        }

        function openMenu() {
            sideMenu.classList.add('open');
            overlay.classList.add('active');
        }

        burger.addEventListener('click', (e) => {
            e.stopPropagation();
            if (sideMenu.classList.contains('open')) closeMenu();
            else openMenu();
        });

        overlay.addEventListener('click', closeMenu);

        // пункты меню (заглушки для демонстрации навигации, дизайн не требует функционала, но я добавлю алерты, чтобы показать работу)
        const navHome = document.getElementById('navHome');
        const navAuth = document.getElementById('navAuth');
        const navGames = document.getElementById('navGames');
        const navReading = document.getElementById('navReading');
        const navAbout = document.getElementById('navAbout');
        const navCourses = document.getElementById('navCourses');

        if(navHome) navHome.addEventListener('click', (e) => { e.preventDefault(); closeMenu(); window.scrollTo({top: 0, behavior: 'smooth'}); });
        if(navAuth) navAuth.addEventListener('click', (e) => { e.preventDefault(); closeMenu(); alert('🔐 Форма регистрации и входа — здесь будет удобная авторизация.'); });
        if(navGames) navGames.addEventListener('click', (e) => { e.preventDefault(); closeMenu(); document.querySelector('.games-grid').scrollIntoView({behavior: 'smooth', block: 'start'}); });
        if(navReading) navReading.addEventListener('click', (e) => { e.preventDefault(); closeMenu(); document.querySelector('.reading-section').scrollIntoView({behavior: 'smooth', block: 'start'}); });
        if(navAbout) navAbout.addEventListener('click', (e) => { e.preventDefault(); closeMenu(); alert('ℹ️ English Trainer — интерактивная платформа для изучения английского через игры и чтение. Создано для эффективного обучения.'); });
        if(navCourses) navCourses.addEventListener('click', (e) => { e.preventDefault(); closeMenu(); alert('🎓 Расширенные курсы: индивидуальный план, уроки с носителем, доступ к библиотеке. Скоро запуск!'); });

        // небольшие эффекты для карточек игр: при клике на игру — +XP (чисто дизайн, но пусть будет)
        const gameLinks = document.querySelectorAll('.games-grid .menu-item');
        gameLinks.forEach(link => {
            link.addEventListener('click', (e) => {
                let gain = Math.floor(Math.random() * 12) + 6;
                window.addXP(gain);
                let msg = document.createElement('div');
                msg.innerText = `+${gain} XP`;
                msg.style.position = 'fixed';
                msg.style.bottom = '20px';
                msg.style.right = '20px';
                msg.style.background = '#10b981';
                msg.style.color = 'white';
                msg.style.padding = '6px 14px';
                msg.style.borderRadius = '40px';
                msg.style.fontWeight = 'bold';
                msg.style.zIndex = '999';
                document.body.appendChild(msg);
                setTimeout(() => msg.remove(), 800);
            });
        });
    })();
</script>
<script src="/xp.js"></script>
</body>
</html>
